{
  "manifest_version": 3,
  "name": "Query Feature Parser",
  "version": "1.0.0",
  "description": "Chrome extension for parsing and managing URL query parameters",
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
